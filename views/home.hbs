<h1>Todos ({{totalCount}} total, {{pendingCount}} pending, {{completedCount}} done)</h1>

{{#if error}}
  <div style="color: red; margin-bottom: 10px;">{{error}}</div>
{{/if}}

<form action="/todos" method="POST" style="margin: 20px 0;">
  <input type="text" name="text" placeholder="Add new todo" required maxlength="500" style="width: 70%; padding: 5px;" />
  <button type="submit" style="padding: 5px 15px;">Add</button>
</form>

<h2>Pending ({{pendingCount}})</h2>
<ul>
  {{#each pending}}
  <li style="margin-bottom: 10px;">
    <form action="/todos/{{id}}/toggle" method="POST" style="display: inline;">
      <button type="submit" style="margin-right: 10px;">✓</button>
    </form>
    {{text}}
    <a href="/todos/{{id}}/edit" style="margin-left: 10px;">Edit</a>
    <form action="/todos/{{id}}/delete" method="POST" style="display: inline; margin-left: 10px;" onsubmit="return confirm('Delete?')">
      <button type="submit">Delete</button>
    </form>
  </li>
  {{/each}}
</ul>

<h2>Completed ({{completedCount}})</h2>
<ul>
  {{#each completed}}
  <li style="margin-bottom: 10px; opacity: 0.7;">
    <form action="/todos/{{id}}/toggle" method="POST" style="display: inline;">
      <button type="submit" style="margin-right: 10px;">↶</button>
    </form>
    <span style="text-decoration: line-through;">{{text}}</span>
    <form action="/todos/{{id}}/delete" method="POST" style="display: inline; margin-left: 10px;" onsubmit="return confirm('Delete?')">
      <button type="submit">Delete</button>
    </form>
  </li>
  {{/each}}
</ul>

{{#unless todos.length}}
<p>No todos yet</p>
{{/unless}}
